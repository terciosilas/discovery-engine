# Discovery Engine — Variáveis de Ambiente
# COPIE este arquivo para .env e preencha com suas credenciais
# NUNCA commite o arquivo .env no git

# Semantic Scholar API (opcional, aumenta rate limit)
SEMANTIC_SCHOLAR_API_KEY=

# Claude API (para resumo de papers)
ANTHROPIC_API_KEY=

# GitHub Token (para repo privado)
GITHUB_TOKEN=

# PubMed API (E-utilities — grátis, mas key aumenta rate limit)
NCBI_API_KEY=
