bibliography/*.pdf

# Outputs dados (ficam no Google Drive)
outputs/*.json
outputs/*.xlsx
outputs/*.csv
# Relatorios markdown vao pro git
!outputs/*.md

# Audit logs (append-only, ficam no Google Drive)
audit_logs/*.json
audit_logs/*.log

